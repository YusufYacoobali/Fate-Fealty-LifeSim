{
  "expo": {
    "name": "Medieval Life",
    "slug": "medieval-life-simulator",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon/icon_ios.png",
    "userInterfaceStyle": "light",
    "scheme": "medievallife",
    "splash": {
      "backgroundColor": "#0d1b2e",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yacoobali.med",
      "icon": "./assets/icon/icon_ios.png"
    },
    "android": {
      "package": "com.yacoobali.med",
      "icon": "./assets/icon/icon_android.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon/icon_android.png",
        "backgroundColor": "#0d1b2e"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "bb28a220-3a1e-4c84-8e16-7525b1117aed"
      }
    }
  }
}
